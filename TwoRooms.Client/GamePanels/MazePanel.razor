@using Microsoft.AspNetCore.SignalR.Client
@using TwoRooms.Client.Game
@implements IDisposable

@if (_completed is not null)
{
    <div class="alert alert-success">
        Solved in @FormatMs(_completed.CompletionMs) with @_completed.MoveCount moves and @_completed.BumpCount bumps.
        @if (_completed.BestCompletionMs is not null)
        {
            <text> Best so far: @FormatMs(_completed.BestCompletionMs.Value).</text>
        }
    </div>
}

@if (ShowNewMazeButton)
{
    <div class="mb-3">
        <button class="btn btn-outline-primary" @onclick="NewMazeAsync">
            @(_completed is null ? "Restart Maze" : "New Maze")
        </button>
    </div>
}

@if (MySeat == SessionSeat.A)
{
    @if (_layout is not null)
    {
        <div class="maze-grid" style="grid-template-columns: repeat(@_layout.Width, 26px);">
            @for (var y = 0; y < _layout.Height; y++)
            {
                for (var x = 0; x < _layout.Width; x++)
                {
                    var cell = _layout.Cells[y * _layout.Width + x];
                    var isStart = x == _layout.StartX && y == _layout.StartY;
                    var isExit = x == _layout.ExitX && y == _layout.ExitY;
                    <div class="maze-cell @CellClasses(cell) @(isExit ? "maze-exit" : "") @(isStart ? "maze-start" : "")">
                        @(isExit ? "X" : isStart ? "S" : "")
                    </div>
                }
            }
        </div>
        <p class="form-text mt-2">S = start, X = exit. You won't see your partner's position &mdash; ask them where they are.</p>
    }
}
else
{
    @if (_position is not null)
    {
        <div class="explorer-panel" tabindex="0" @onkeydown="HandleKeyDown">
            <div class="compass">
                <button class="compass-btn compass-n" disabled="@(!_position.Surroundings.North)" @onclick='() => MoveAsync(MazeDirection.North)'>&#9650;</button>
                <button class="compass-btn compass-w" disabled="@(!_position.Surroundings.West)" @onclick='() => MoveAsync(MazeDirection.West)'>&#9664;</button>
                <div class="compass-center">(@_position.X, @_position.Y)</div>
                <button class="compass-btn compass-e" disabled="@(!_position.Surroundings.East)" @onclick='() => MoveAsync(MazeDirection.East)'>&#9654;</button>
                <button class="compass-btn compass-s" disabled="@(!_position.Surroundings.South)" @onclick='() => MoveAsync(MazeDirection.South)'>&#9660;</button>
            </div>
            <p class="form-text mt-2">
                Moves: @_position.MoveCount &nbsp;|&nbsp; Bumps: @_position.BumpCount
                <br />Arrow keys / WASD also work. Describe your surroundings to the Guide!
            </p>
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public HubConnection Hub { get; set; } = null!;
    [Parameter, EditorRequired] public string SessionCode { get; set; } = "";
    [Parameter, EditorRequired] public SessionSeat MySeat { get; set; }
    [Parameter] public bool ShowNewMazeButton { get; set; } = true;
    [Parameter] public EventCallback OnSolved { get; set; }

    private MazeLayoutUpdate? _layout;
    private MazePositionUpdate? _position;
    private MazeCompletedMessage? _completed;
    private readonly List<IDisposable> _subscriptions = [];

    protected override void OnInitialized()
    {
        _subscriptions.Add(Hub.On<MazeLayoutUpdate>("OnMazeLayout", async update =>
        {
            _layout = update;
            if (!update.Solved) _completed = null;
            await InvokeAsync(StateHasChanged);
        }));

        _subscriptions.Add(Hub.On<MazePositionUpdate>("OnMazePosition", async update =>
        {
            _position = update;
            if (!update.Solved) _completed = null;
            await InvokeAsync(StateHasChanged);
        }));

        _subscriptions.Add(Hub.On<MazeCompletedMessage>("OnMazeCompleted", async result =>
        {
            _completed = result;
            await InvokeAsync(StateHasChanged);
            await OnSolved.InvokeAsync();
        }));

        // Explicitly pull current state on mount, retrying briefly: a server-side push (e.g. from
        // a campaign stage activating just before this panel exists) can otherwise arrive before
        // this component finishes mounting and registering its handlers, and be silently missed
        // (no handler yet == the message is just dropped). One request isn't reliably enough of a
        // do-over if that request itself loses the same race, so keep asking until data shows up.
        _ = RequestStateWithRetry();
    }

    private async Task RequestStateWithRetry()
    {
        for (var attempt = 0; attempt < 5 && _layout is null && _position is null; attempt++)
        {
            await Hub.SendAsync("RequestMazeState", SessionCode);
            await Task.Delay(400);
        }
    }

    private async Task MoveAsync(MazeDirection direction)
    {
        if (MySeat != SessionSeat.B) return;
        await Hub.SendAsync("MazeMove", SessionCode, direction);
    }

    private async Task NewMazeAsync()
    {
        await Hub.SendAsync("NewMaze", SessionCode);
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        var direction = e.Key switch
        {
            "ArrowUp" or "w" or "W" => MazeDirection.North,
            "ArrowRight" or "d" or "D" => MazeDirection.East,
            "ArrowDown" or "s" or "S" => MazeDirection.South,
            "ArrowLeft" or "a" or "A" => MazeDirection.West,
            _ => (MazeDirection?)null
        };
        if (direction is not null)
        {
            await MoveAsync(direction.Value);
        }
    }

    private static string CellClasses(MazeCellDto c)
    {
        var classes = new List<string>();
        if (!c.North) classes.Add("wall-n");
        if (!c.East) classes.Add("wall-e");
        if (!c.South) classes.Add("wall-s");
        if (!c.West) classes.Add("wall-w");
        return string.Join(" ", classes);
    }

    private static string FormatMs(long ms) => $"{ms / 1000.0:0.0}s";

    public void Dispose()
    {
        foreach (var sub in _subscriptions) sub.Dispose();
    }
}
