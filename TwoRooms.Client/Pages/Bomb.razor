@page "/bomb"
@using Microsoft.AspNetCore.SignalR.Client
@using TwoRooms.Client.Game
@using TwoRooms.Client.GamePanels
@implements IAsyncDisposable
@inject NavigationManager Navigation

<PageTitle>Bomb Defusal</PageTitle>

<a href="" class="back-link">&lsaquo; Menu</a>
<h1>Bomb Defusal</h1>
<p class="text-muted">
    One of you is the <strong>Wire Viewer</strong> &mdash; you see the wires and do the cutting, but
    you don't have the manual. The other is the <strong>Manual Holder</strong> &mdash; you have the
    rules, but can't see or touch the wires. Describe what you see, work out which wire it is
    together, before the timer runs out. Cut the wrong one and it's over.
</p>

@if (_stage == Stage.Join)
{
    <div class="card p-3" style="max-width: 420px;">
        <div class="mb-3">
            <label class="form-label">Your name</label>
            <input class="form-control" @bind="_playerName" @bind:event="oninput" maxlength="24" />
        </div>
        <div class="mb-3">
            <label class="form-label">Session code</label>
            <div class="input-group">
                <input class="form-control" @bind="_sessionCode" @bind:event="oninput" maxlength="8"
                       placeholder="e.g. FOX7" />
                <button class="btn btn-outline-secondary" type="button" @onclick="GenerateCode">New Code</button>
            </div>
            <div class="form-text">Share this code with your opponent so they can join the same session.</div>
        </div>
        @if (_joinError is not null)
        {
            <div class="alert alert-danger py-2">@_joinError</div>
        }
        <button class="btn btn-primary" disabled="@_connecting" @onclick="JoinAsync">
            @(_connecting ? "Connecting..." : "Join Session")
        </button>
    </div>
}
else
{
    <div class="mb-3">
        <strong>Session:</strong> @_sessionCode &nbsp;|&nbsp;
        <strong>You are the:</strong> @(_mySeat == SessionSeat.A ? "Wire Viewer (sees the wires, cuts)" : "Manual Holder (reads the rules)")
        <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="LeaveAsync">Leave</button>
    </div>

    <div class="mb-3">
        @foreach (var p in _players)
        {
            <span class="badge @(p.IsConnected ? "bg-success" : "bg-secondary") me-2">
                @p.Name (@(p.Seat == SessionSeat.A ? "Wire Viewer" : "Manual Holder")) @(p.IsConnected ? "" : "- disconnected")
            </span>
        }
    </div>

    @if (!_bothConnected)
    {
        <p>Waiting for your partner to join session "@_sessionCode"...</p>
    }

    @if (_hub is not null)
    {
        <BombPanel Hub="_hub" SessionCode="@_sessionCode" MySeat="_mySeat" />
    }
}

@code {
    private enum Stage { Join, Playing }

    private Stage _stage = Stage.Join;
    private HubConnection? _hub;

    private string _playerName = "";
    private string _sessionCode = "";
    private string? _joinError;
    private bool _connecting;

    private SessionSeat _mySeat;
    private IReadOnlyList<PlayerInfo> _players = [];
    private bool _bothConnected;

    private void GenerateCode()
    {
        const string alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        Span<char> chars = stackalloc char[4];
        for (var i = 0; i < chars.Length; i++)
        {
            chars[i] = alphabet[Random.Shared.Next(alphabet.Length)];
        }
        _sessionCode = new string(chars);
    }

    // Generated fresh per page load rather than persisted to browser storage: sessionStorage is
    // inherited when a tab is opened via "Duplicate", which made two duplicated windows collide
    // into the same seat. A fresh in-memory token guarantees every window is a distinct player.
    private static string CreatePlayerToken() => Guid.NewGuid().ToString("N");

    private async Task JoinAsync()
    {
        _joinError = null;
        if (string.IsNullOrWhiteSpace(_playerName) || string.IsNullOrWhiteSpace(_sessionCode))
        {
            _joinError = "Enter a name and a session code.";
            return;
        }

        _connecting = true;
        try
        {
            var hub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri(GameConstants.HubPath))
                .WithAutomaticReconnect()
                .Build();

            RegisterHandlers(hub);
            await hub.StartAsync();

            var token = CreatePlayerToken();
            var result = await hub.InvokeAsync<JoinSessionResult>("JoinSession", _sessionCode, _playerName, token);
            if (!result.Success)
            {
                _joinError = result.Error;
                await hub.DisposeAsync();
                return;
            }

            _hub = hub;
            _mySeat = result.Seat;
            _sessionCode = result.SessionCode;
            _stage = Stage.Playing;
        }
        catch (Exception ex)
        {
            _joinError = $"Could not connect: {ex.Message}";
        }
        finally
        {
            _connecting = false;
        }
    }

    private async Task LeaveAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
            _hub = null;
        }
        _stage = Stage.Join;
        _players = [];
        _joinError = null;
    }

    private void RegisterHandlers(HubConnection hub)
    {
        hub.On<SessionStateUpdate>("OnSessionState", async update =>
        {
            _players = update.Players;
            _bothConnected = update.BothConnected;
            await InvokeAsync(StateHasChanged);
        });
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
}
