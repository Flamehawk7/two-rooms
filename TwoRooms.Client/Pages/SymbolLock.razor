@page "/lock"
@using Microsoft.AspNetCore.SignalR.Client
@using TwoRooms.Client.Game
@implements IAsyncDisposable
@inject NavigationManager Navigation

<PageTitle>Symbol Lock</PageTitle>

<a href="" class="back-link">&lsaquo; Menu</a>
<h1>Symbol Lock</h1>
<p class="text-muted">
    One of you is the <strong>Reader</strong> &mdash; you see the symbols shown on the door, but not
    what they mean. The other is the <strong>Codex Keeper</strong> &mdash; you have the codex that
    maps symbols to digits, but can't see the door. Describe the symbols to each other and work out
    the code together.
</p>

@if (_stage == Stage.Join)
{
    <div class="card p-3" style="max-width: 420px;">
        <div class="mb-3">
            <label class="form-label">Your name</label>
            <input class="form-control" @bind="_playerName" @bind:event="oninput" maxlength="24" />
        </div>
        <div class="mb-3">
            <label class="form-label">Session code</label>
            <div class="input-group">
                <input class="form-control" @bind="_sessionCode" @bind:event="oninput" maxlength="8"
                       placeholder="e.g. FOX7" />
                <button class="btn btn-outline-secondary" type="button" @onclick="GenerateCode">New Code</button>
            </div>
            <div class="form-text">Share this code with your opponent so they can join the same session.</div>
        </div>
        @if (_joinError is not null)
        {
            <div class="alert alert-danger py-2">@_joinError</div>
        }
        <button class="btn btn-primary" disabled="@_connecting" @onclick="JoinAsync">
            @(_connecting ? "Connecting..." : "Join Session")
        </button>
    </div>
}
else
{
    <div class="mb-3">
        <strong>Session:</strong> @_sessionCode &nbsp;|&nbsp;
        <strong>You are the:</strong> @(_mySeat == SessionSeat.A ? "Reader (sees the door)" : "Codex Keeper (has the mapping)")
        <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="LeaveAsync">Leave</button>
    </div>

    <div class="mb-3">
        @foreach (var p in _players)
        {
            <span class="badge @(p.IsConnected ? "bg-success" : "bg-secondary") me-2">
                @p.Name (@(p.Seat == SessionSeat.A ? "Reader" : "Codex Keeper")) @(p.IsConnected ? "" : "- disconnected")
            </span>
        }
    </div>

    @if (!_bothConnected)
    {
        <p>Waiting for your partner to join session "@_sessionCode"...</p>
    }

    @if (_completed is not null)
    {
        <div class="alert alert-success">
            Lock opened in @FormatMs(_completed.TotalElapsedMs) with @_completed.TotalMistakeCount mistakes.
            @if (_completed.BestCompletionMs is not null)
            {
                <text> Best so far: @FormatMs(_completed.BestCompletionMs.Value).</text>
            }
        </div>
    }
    else if ((_door?.StageSolved ?? _codex?.StageSolved ?? false))
    {
        <div class="alert alert-success">
            Stage solved!
            <button class="btn btn-sm btn-success ms-2" @onclick="AdvanceStageAsync">Continue</button>
        </div>
    }

    <div class="mb-3">
        <span class="me-2">New lock:</span>
        <button class="btn btn-sm btn-outline-primary me-2" @onclick='() => NewLockAsync(LockDifficulty.Single)'>Single Lock</button>
        <button class="btn btn-sm btn-outline-primary" @onclick='() => NewLockAsync(LockDifficulty.MultiStage)'>Multi-Stage (3)</button>
    </div>

    @if (_mySeat == SessionSeat.A)
    {
        @if (_door is not null)
        {
            <p class="form-text">Stage @_door.Stage of @_door.TotalStages (@DifficultyLabel(_door.Difficulty))</p>
            <div class="symbol-row">
                @foreach (var symbol in _door.DoorSymbols)
                {
                    <span class="symbol-tile">@symbol</span>
                }
            </div>
            <p class="form-text mt-2">Describe these symbols (shape, in order) to the Codex Keeper.</p>
        }
    }
    else
    {
        @if (_codex is not null)
        {
            <p class="form-text">
                Stage @_codex.Stage of @_codex.TotalStages (@DifficultyLabel(_codex.Difficulty))
                &nbsp;|&nbsp; Mistakes: @_codex.StageMistakeCount (@_codex.TotalMistakeCount total)
            </p>
            <table class="table table-sm codex-table" style="max-width: 260px;">
                <thead>
                    <tr><th>Symbol</th><th>Digit</th></tr>
                </thead>
                <tbody>
                    @foreach (var entry in _codex.Codex)
                    {
                        <tr><td class="symbol-tile-sm">@entry.Symbol</td><td>@entry.Digit</td></tr>
                    }
                </tbody>
            </table>

            <div class="input-group" style="max-width: 300px;">
                <input class="form-control" @bind="_codeInput" @bind:event="oninput"
                       disabled="@_codex.StageSolved" placeholder="Enter the code"
                       @onkeydown="HandleCodeKeyDown" />
                <button class="btn btn-primary" disabled="@_codex.StageSolved" @onclick="SubmitCodeAsync">Submit</button>
            </div>
        }
    }
}

@code {
    private enum Stage { Join, Playing }

    private Stage _stage = Stage.Join;
    private HubConnection? _hub;

    private string _playerName = "";
    private string _sessionCode = "";
    private string? _joinError;
    private bool _connecting;

    private SessionSeat _mySeat;
    private IReadOnlyList<PlayerInfo> _players = [];
    private bool _bothConnected;

    private DoorViewUpdate? _door;
    private CodexViewUpdate? _codex;
    private SymbolLockCompletedMessage? _completed;
    private string _codeInput = "";

    private void GenerateCode()
    {
        const string alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        Span<char> chars = stackalloc char[4];
        for (var i = 0; i < chars.Length; i++)
        {
            chars[i] = alphabet[Random.Shared.Next(alphabet.Length)];
        }
        _sessionCode = new string(chars);
    }

    // Generated fresh per page load rather than persisted to browser storage: sessionStorage is
    // inherited when a tab is opened via "Duplicate", which made two duplicated windows collide
    // into the same seat. A fresh in-memory token guarantees every window is a distinct player.
    private static string CreatePlayerToken() => Guid.NewGuid().ToString("N");

    private async Task JoinAsync()
    {
        _joinError = null;
        if (string.IsNullOrWhiteSpace(_playerName) || string.IsNullOrWhiteSpace(_sessionCode))
        {
            _joinError = "Enter a name and a session code.";
            return;
        }

        _connecting = true;
        try
        {
            var hub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri(GameConstants.HubPath))
                .WithAutomaticReconnect()
                .Build();

            RegisterHandlers(hub);
            await hub.StartAsync();

            var token = CreatePlayerToken();
            var result = await hub.InvokeAsync<JoinSessionResult>("JoinSession", _sessionCode, _playerName, token);
            if (!result.Success)
            {
                _joinError = result.Error;
                await hub.DisposeAsync();
                return;
            }

            _hub = hub;
            _mySeat = result.Seat;
            _sessionCode = result.SessionCode;
            _stage = Stage.Playing;
        }
        catch (Exception ex)
        {
            _joinError = $"Could not connect: {ex.Message}";
        }
        finally
        {
            _connecting = false;
        }
    }

    private async Task LeaveAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
            _hub = null;
        }
        _stage = Stage.Join;
        _players = [];
        _door = null;
        _codex = null;
        _completed = null;
        _codeInput = "";
        _joinError = null;
    }

    private async Task SubmitCodeAsync()
    {
        if (_hub is null || _mySeat != SessionSeat.B || string.IsNullOrWhiteSpace(_codeInput)) return;
        await _hub.SendAsync("SubmitSymbolLockCode", _sessionCode, _codeInput.Trim());
        _codeInput = "";
    }

    private async Task HandleCodeKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitCodeAsync();
    }

    private async Task AdvanceStageAsync()
    {
        if (_hub is null) return;
        await _hub.SendAsync("AdvanceSymbolLockStage", _sessionCode);
    }

    private async Task NewLockAsync(LockDifficulty difficulty)
    {
        if (_hub is null) return;
        await _hub.SendAsync("NewSymbolLock", _sessionCode, difficulty);
    }

    private static string DifficultyLabel(LockDifficulty difficulty) =>
        difficulty == LockDifficulty.Single ? "Single Lock" : "Multi-Stage";

    private static string FormatMs(long ms) => $"{ms / 1000.0:0.0}s";

    private void RegisterHandlers(HubConnection hub)
    {
        hub.On<SessionStateUpdate>("OnSessionState", async update =>
        {
            _players = update.Players;
            _bothConnected = update.BothConnected;
            await InvokeAsync(StateHasChanged);
        });

        hub.On<DoorViewUpdate>("OnSymbolLockDoor", async update =>
        {
            _door = update;
            if (!update.AllStagesSolved) _completed = null;
            await InvokeAsync(StateHasChanged);
        });

        hub.On<CodexViewUpdate>("OnSymbolLockCodex", async update =>
        {
            _codex = update;
            if (!update.AllStagesSolved) _completed = null;
            await InvokeAsync(StateHasChanged);
        });

        hub.On<SymbolLockStageResultMessage>("OnSymbolLockStageResult", async _ =>
        {
            await InvokeAsync(StateHasChanged);
        });

        hub.On<SymbolLockCompletedMessage>("OnSymbolLockCompleted", async result =>
        {
            _completed = result;
            await InvokeAsync(StateHasChanged);
        });
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
}
